# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# JWT Authentication
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# Cloud Run (Gemini API) - Stage 1: Primary AI provider
CLOUD_RUN_URL=https://gemini-generate-fn-513563150820.asia-northeast1.run.app

# Gemini API Direct (Google AI Studio) - Stage 2: Fallback AI provider (free tier)
# Get your API key from: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash

# Google Custom Search (optional - for company research)
# GOOGLE_SEARCH_API_KEY=your-google-api-key
# GOOGLE_SEARCH_CX=your-custom-search-engine-id

# NextAuth (optional - if using NextAuth)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-nextauth-secret
